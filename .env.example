# Public base URL used when generating approval and tracking links.
# Leave blank for local development to fall back to the browser origin.
APP_URL=

# Zoho OAuth / Books integration.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=
ZOHO_ORG_ID=

# JSON string for Firebase Admin SDK usage in serverless functions.
# Example:
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
FIREBASE_SERVICE_ACCOUNT_KEY=
